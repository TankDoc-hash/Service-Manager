# ─────────────────────────────────────────────────
# TankDOC Service Manager — Environment Variables
# Copy this to .env.local for development
# Add all these to Vercel Dashboard → Settings → Environment Variables for production
# ─────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ──────────────────
# Get from: https://neon.tech → New Project → Connection String
DATABASE_URL="postgresql://neondb_owner:npg_9u8nxWfiIpYN@ep-shiny-pine-adfel8qh-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── WhatsApp Cloud API (Meta) ───────────────────
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="123456789012345"

# Your own WhatsApp number (with country code, no +)
# This is where reminders will be sent TO
OWNER_WHATSAPP_NUMBER="919876543210"

# ── Cron Job Security ────────────────────────────
# Generate a random secret: openssl rand -base64 32
# Add this same value to Vercel → Settings → Cron Job Secret
CRON_SECRET="your-random-secret-here"

# ── JWT Authentication ─────────────────────────
# Generate a random secret: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here-change-in-production"
